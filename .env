# .env — variables de entorno para docker-compose
COMPOSE_PROJECT_NAME=esport

# Base de datos
DB_NAME=esport_database
DB_USER=admin
DB_PASS=password

# Redis
REDIS_PASS=redis_pass

# RabbitMQ
RABBIT_USER=esport
RABBIT_PASS=esport_pass

# LocalStack — credenciales fake
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
